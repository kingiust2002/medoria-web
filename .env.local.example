# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL + anon (publishable) key from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_publishable_key

# ── Contact channels ──────────────────────────────────────────────────────────
NEXT_PUBLIC_WA_NUMBER=992XXXXXXXXX        # WhatsApp number, digits only, no +
NEXT_PUBLIC_TG_USERNAME=medoria_tj         # Telegram username, no @
NEXT_PUBLIC_PHONE=+992XXXXXXXXX            # Phone quote channel (tel:)
NEXT_PUBLIC_EMAIL=sales@medoria.tj         # Contact email (mailto:)

# ── AI assistant (optional) ─────────────────────────────────────────────────────
# Powers the floating "Medoria Assistant" chat. The provider is chosen by which
# key is present (Gemini first, then Hugging Face, then Anthropic). If NONE is set
# the widget gracefully falls back to WhatsApp/Telegram — the site works without it.
# All keys here are SERVER-ONLY: never prefix them with NEXT_PUBLIC_ (that would
# ship the secret to the browser).

# Option A — Google Gemini (recommended). FREE key from Google AI Studio
# (https://aistudio.google.com/apikey) — no billing/credit card needed.
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional model override (default: gemini-2.0-flash — fast & multilingual).
# GEMINI_MODEL=gemini-2.0-flash

# Option B — Hugging Face (OpenAI-compatible Inference Providers router).
# HUGGING_FACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional model override (default: Qwen/Qwen2.5-72B-Instruct — strong multilingual).
# HF_MODEL=Qwen/Qwen2.5-72B-Instruct
# Optional endpoint override for any OpenAI-compatible gateway (self-hosted TGI/
# vLLM, a proxy, etc.). Defaults to the Hugging Face router.
# HF_BASE_URL=https://router.huggingface.co/v1/chat/completions

# Option C — Anthropic (Claude). Used only when the keys above are unset.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-opus-4-8

# ── Operator panel (/operator) — ALL SERVER-ONLY, never NEXT_PUBLIC_ ───────────
# 1) Service-role key from Supabase → Settings → API. Grants full DB + Storage
#    access. Used ONLY in server actions / route handlers. NEVER exposed to the
#    browser. Without it the panel can read but cannot write/upload.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 2) Operator login password stored as a scrypt hash (NOT plaintext).
#    Generate it (prints a "scrypt:salt:hash" string — paste that here):
#      node scripts/hash-operator-password.mjs 'YourStrongPassword'
OPERATOR_PASSWORD_HASH=scrypt:REPLACE_ME

# 3) Secret used to sign the operator session cookie. REQUIRED — the panel
#    refuses to authenticate if this is missing or shorter than 16 chars.
#    Generate a long random value:
#      node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
OPERATOR_SESSION_SECRET=REPLACE_ME_with_a_long_random_string

# 4) Optional: operator session lifetime in hours (default 8).
# OPERATOR_SESSION_TTL_HOURS=8

# 5) Optional: Google Cloud Translation API key (server-only) — powers the
#    "auto-translate" button in the product form (fills RU/TG/EN from one language).
#    Setup: Google Cloud Console → enable "Cloud Translation API" → create an API
#    key → (recommended) restrict it to the Cloud Translation API. Supports Tajik.
# GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key
