# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL + anon (publishable) key from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_publishable_key

# ── Contact channels ──────────────────────────────────────────────────────────
NEXT_PUBLIC_WA_NUMBER=992XXXXXXXXX        # WhatsApp number, digits only, no +
NEXT_PUBLIC_TG_USERNAME=medoria_tj         # Telegram username, no @
NEXT_PUBLIC_PHONE=+992XXXXXXXXX            # Phone quote channel (tel:)
NEXT_PUBLIC_EMAIL=sales@medoria.tj         # Contact email (mailto:)

# ── AI assistant (optional) ─────────────────────────────────────────────────────
# Server-side key for the floating "Medoria Assistant" chat. If unset, the
# widget gracefully falls back to WhatsApp/Telegram — the site works without it.
# NEVER prefix this with NEXT_PUBLIC_ (it must stay server-only, never shipped
# to the browser).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional model override. Defaults to claude-opus-4-8. For a high-traffic
# public chat you can switch to a cheaper model, e.g. claude-haiku-4-5.
ANTHROPIC_MODEL=claude-opus-4-8
